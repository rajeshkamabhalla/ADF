{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfrajesh6677"
		},
		"AzureSqllinked server_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqllinked server'"
		},
		"azuresqldatasets_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'azuresqldatasets'"
		},
		"gen2linked server_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'gen2linked server'"
		},
		"AzureSqllinked server_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "batch03sqlserver.database.windows.net"
		},
		"AzureSqllinked server_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "free-sql-db-2443724"
		},
		"AzureSqllinked server_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "rajesh"
		},
		"azuresqldatasets_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "batch03sqlserver.database.windows.net"
		},
		"azuresqldatasets_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "free-sql-db-2443724"
		},
		"azuresqldatasets_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "rajesh"
		},
		"gen2linked server_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storagebatch03rajesh.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfrajesh6677_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureSqllinked server_password": {
						"value": "[parameters('AzureSqllinked server_password')]"
					},
					"azuresqldatasets_password": {
						"value": "[parameters('azuresqldatasets_password')]"
					},
					"gen2linked server_accountKey": {
						"value": "[parameters('gen2linked server_accountKey')]"
					},
					"AzureSqllinked server_properties_typeProperties_server": {
						"value": "[parameters('AzureSqllinked server_properties_typeProperties_server')]"
					},
					"AzureSqllinked server_properties_typeProperties_database": {
						"value": "[parameters('AzureSqllinked server_properties_typeProperties_database')]"
					},
					"AzureSqllinked server_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqllinked server_properties_typeProperties_userName')]"
					},
					"azuresqldatasets_properties_typeProperties_server": {
						"value": "[parameters('azuresqldatasets_properties_typeProperties_server')]"
					},
					"azuresqldatasets_properties_typeProperties_database": {
						"value": "[parameters('azuresqldatasets_properties_typeProperties_database')]"
					},
					"azuresqldatasets_properties_typeProperties_userName": {
						"value": "[parameters('azuresqldatasets_properties_typeProperties_userName')]"
					},
					"gen2linked server_properties_typeProperties_url": {
						"value": "[parameters('gen2linked server_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adfrajesh6677_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adfrajesh6677_ArmTemplate_0')]"
			]
		}
	]
}